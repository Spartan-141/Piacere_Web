{
  "name": "piacere-2",
  "private": true,
  "version": "0.0.1",
  "description": "Sistema integral de gestión y ventas para Pizzería Piacere",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:backend": "turbo run dev --filter=backend",
    "dev:admin": "turbo run dev --filter=admin",
    "dev:web": "turbo run dev --filter=web"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
